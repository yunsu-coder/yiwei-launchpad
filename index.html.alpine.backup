<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover, maximum-scale=1.0, user-scalable=no">
<title>导航页</title>
<link rel="stylesheet" href="/css/styles.css">
<script src="/lib/jszip/dist/jszip.min.js"></script>
<script src="/lib/epubjs/dist/epub.min.js"></script>
<script src="https://unpkg.com/vue@3/dist/vue.global.prod.js"></script>
</head>
<body>

<nav class="navbar">
  <button class="nav-item active" data-panel="home"><span class="nav-icon">🏠</span><span>首页</span></button>
  <button class="nav-item" data-panel="files"><span class="nav-icon">📁</span><span>文件</span></button>
  <button class="nav-item" data-panel="notes"><span class="nav-icon">📝</span><span>笔记</span></button>
  <button class="nav-item" data-panel="scrape"><span class="nav-icon">🔍</span><span>采集</span></button>
  <button class="nav-item" data-panel="read"><span class="nav-icon">📖</span><span>阅读</span></button>
  <button class="nav-item" data-panel="translate"><span class="nav-icon">🌐</span><span>翻译</span></button>
  <button class="nav-item" data-panel="ai"><span class="nav-icon">🤖</span><span>AI</span></button>
  <button class="nav-item" data-panel="voice"><span class="nav-icon">🎙</span><span>语音</span></button>
  <button class="theme-btn" id="themeBtn" title="主题">🌓</button>
</nav>

<!-- 首页 -->
<div class="panel active" id="panel-home"><div id="home-app" v-cloak><div style="text-align:center;margin-top:.5rem" v-if="!editMode"><button class="btn-sm" @click="editMode=true">⚙️ 编辑</button></div>
<div v-if="editMode" style="margin-top:.8rem;display:flex;gap:1rem;align-items:center;flex-wrap:wrap;font-size:.75rem;color:var(--sub)">
<span>🖼️ 壁纸：</span><input v-model="wallpaper" @change="setWallpaper(wallpaper)" placeholder="图片URL" style="flex:1;min-width:200px;padding:.3rem;border:1px solid var(--border);border-radius:6px;font-size:.75rem;background:var(--card);color:var(--text)"><button class="btn-sm" @click="setWallpaper('')">清除</button><button class="btn-sm" @click="window.startWallpaperRotation(30)">🔄轮换</button><button class="btn-sm" @click="window.stopWallpaperRotation()">⏹停止</button>
<span>🎨 主题色：</span><span v-for="c in ['#4f46e5','#0891b2','#059669','#d97706','#dc2626','#7c3aed','#db2777']" :key="c" @click="setAccent(c)" :style="{background:c,width:'20px',height:'20px',borderRadius:'50%',cursor:'pointer',border:accentColor===c?'2px solid var(--text)':'2px solid transparent'}" title="切换"></span></div>
<div v-if="editMode" style="margin-top:.5rem;font-size:.75rem"><div v-for="(links,cat) in categories" :key="cat" style="margin-bottom:.5rem"><strong>{{ cat }}</strong><div v-for="(l,i) in links" :key="i" style="display:flex;gap:.3rem;align-items:center;margin:.15rem 0"><input v-model="l.icon" maxlength="2" style="width:2rem;font-size:1.2rem;text-align:center;border:none;background:transparent"><input v-model="l.name" style="width:100px"><input v-model="l.url" style="flex:1"><button class="btn-sm danger" @click="delLink(cat,i)">✕</button></div><button class="btn-sm" @click="startAdd(cat)">＋</button></div><div v-if="addForm.cat" style="margin-top:.3rem;display:flex;gap:.3rem"><input v-model="addForm.icon" maxlength="2" style="font-size:1.5rem;width:2rem;text-align:center;border:none;background:transparent"><input v-model="addForm.name" placeholder="名称"><input v-model="addForm.url" placeholder="URL"><button class="btn-sm" @click="addLink">添加</button></div><button class="btn-sm" @click="resetDefault">恢复默认</button><button class="btn-sm" @click="editMode=false" style="margin-left:.5rem">完成</button></div>
  <div class="clock-date"><span id="clock">00:00:00</span><span id="date"></span></div>
  <form id="searchForm" class="search-box"><input id="q" placeholder="Bing 搜索..."><button>🔍</button></form>
  <div id="status"></div>
  <div class="bookmarks"><div v-for="(links,cat) in categories" :key="cat" class="bm-group"><div class="bm-cat">{{ {ai:'🤖',common:'🌐',dev:'🛠',tools:'🧰'}[cat] }}</div><div class="bm-links"><a v-for="(l,i) in links" :key="l.url" :href="l.url" target="_blank" class="bm-link"><span class="bm-icon">{{ l.icon }}</span><span>{{ l.name }}</span></a></div></div></div>
  id="files-app" v-cloak><h2>📁 文件中转站</h2>
<div class="storage-bar"><div class="label"><span>已用 {{ storage.used_h }} / 20GB</span><span>{{ storage.pct }}%</span></div><div class="bar"><div class="fill" :class="storage.pct<60?'low':storage.pct<85?'mid':'high'" :style="{width:Math.min(storage.pct,100)+'%'}"></div></div></div>
<div class="drop-zone" :class="{'drag-over':dropActive}" @click="$refs.fileInput.click()" @dragover.prevent="dropActive=true" @dragleave="dropActive=false" @drop.prevent="dropActive=false;upload($event)"><div class="icon">📤</div><div class="hint">拖拽文件上传，或 <strong>点击选择文件</strong></div><input type="file" ref="fileInput" multiple @change="upload" style="display:none"></div>
<div v-if="uploadProgress" style="margin-bottom:.5rem;font-size:.8rem;color:var(--accent)">{{ uploadProgress }}</div>
<div style="display:flex;gap:.5rem;margin-bottom:.8rem;align-items:center"><input type="text" v-model="search" placeholder="搜索文件名..."><select v-model="sort"><option value="date-desc">时间↓</option><option value="date-asc">时间↑</option><option value="name-asc">名称A-Z</option><option value="name-desc">名称Z-A</option><option value="size-desc">大小↓</option><option value="size-asc">大小↑</option></select></div>
<div v-if="hasSelection" style="display:flex;align-items:center;gap:.5rem;margin-bottom:.5rem;padding:.4rem .6rem;background:var(--card);border:1px solid var(--border);border-radius:8px;font-size:.8rem"><label style="cursor:pointer"><input type="checkbox" :checked="allSelected" @change="toggleSelectAll">全选</label><span style="color:var(--accent)">已选{{selectedList.length}}个</span><button class="btn-sm danger" @click="batchDelete" style="margin-left:auto">🗑删除选中</button></div>
<div class="file-list" v-if="filtered.length"><div class="file-row" v-for="f in filtered" :key="f.name"><input type="checkbox" v-model="selected[f.name]"><span class="fname" v-if="renaming?.old!==f.name" @click="preview(f.name)" style="cursor:pointer;color:var(--accent)">📄{{f.name}}</span><input v-else v-model="renaming.new" @keydown.enter="doRename" @keydown.escape="cancelRename" @blur="doRename" autofocus><span class="fsize">{{fmtSize(f.size)}}</span><span class="fsize">{{new Date(f.mtime).toLocaleDateString('zh-CN')}}</span><div class="actions"><button v-if="f.name.match(/\.(jpg|jpeg|png|gif|webp|svg)$/i)" class="btn-sm" @click="setBg(f.name)">🖼️设壁纸</button><button class="btn-sm" @click="copyLink(f.name)">复制链接</button><button class="btn-sm" @click="startRename(f.name)">重命名</button><button class="btn-sm danger" @click="delFile(f.name)">删除</button></div></div></div>
<div class="empty-state" v-else>暂无文件，上传一个吧</div>
  <h2>📁 文件中转站</h2>
  <div class="storage-bar"><div class="label"><span>已用 {{ storage.used_h }} / 20GB</span><span>{{ storage.pct }}%</span></div><div class="bar"><div class="fill" :class="storage.pct<60?'low':storage.pct<85?'mid':'high'" :style="{width:Math.min(storage.pct,100)+'%'}"></div></div></div>
  <div class="hint">拖拽文件上传，或 <strong>点击选择文件</strong></div><input type="file" ref="fileInput" multiple @change="upload" style="display:none"></div>
  <div v-if="uploadProgress" style="margin-bottom:.5rem;font-size:.8rem;color:var(--accent);">{{ uploadProgress }}</div>
  <div style="display:flex;gap:.5rem;margin-bottom:.8rem;align-items:center;"><input type="text" v-model="search" placeholder="搜索文件名..."><select v-model="sort"><option value="date-desc">时间↓</option><option value="date-asc">时间↑</option><option value="name-asc">名称A-Z</option><option value="name-desc">名称Z-A</option><option value="size-desc">大小↓</option><option value="size-asc">大小↑</option></select></div>
  <div v-if="hasSelection" style="display:flex;align-items:center;gap:.5rem;margin-bottom:.5rem;padding:.4rem .6rem;background:var(--card);border:1px solid var(--border);border-radius:8px;font-size:.8rem;"><label style="cursor:pointer;"><input type="checkbox" :checked="allSelected" @change="toggleSelectAll">全选</label><span style="color:var(--accent);">已选{{selectedList.length}}个</span><button class="btn-sm danger" @click="batchDelete" style="margin-left:auto;">🗑删除选中</button></div>
  <div class="file-list" v-if="filtered.length"><div class="file-row" v-for="f in filtered" :key="f.name"><input type="checkbox" v-model="selected[f.name]"><span class="fname" v-if="renaming?.old!==f.name" @click="preview(f.name)" style="cursor:pointer;color:var(--accent);">📄{{f.name}}</span><input v-else v-model="renaming.new" @keydown.enter="doRename" @keydown.escape="cancelRename" @blur="doRename" autofocus><span class="fsize">{{fmtSize(f.size)}}</span><span class="fsize">{{new Date(f.mtime).toLocaleDateString('zh-CN')}}</span><div class="actions"><button v-if="f.name.match(/\.(jpg|jpeg|png|gif|webp|svg)\$/i)" class="btn-sm" @click="setBg(f.name)">🖼️设壁纸</button><button class="btn-sm" @click="copyLink(f.name)">复制链接</button><button class="btn-sm" @click="startRename(f.name)">重命名</button><button class="btn-sm danger" @click="delFile(f.name)">删除</button></div></div></div>
  <div class="empty-state" v-else>暂无文件，上传一个吧</div>
</div>

<!-- 笔记 -->
<div class="panel" id="panel-notes"><div id="notes-app" v-cloak><div class="notes-topbar"><h2>📝 Markdown 笔记</h2></div>
  <div class="notes-layout"><div class="notes-sidebar"><div style="display:flex;gap:.2rem;flex-wrap:wrap;margin-bottom:.4rem;"><button v-for="c in categories" :key="c" class="btn-sm" @click="activeCat=c" :style="{background:activeCat===c?'var(--accent)':'var(--card)',color:activeCat===c?'#fff':'var(--text)'}">{{c}}</button></div><button class="btn-new" @click="newNote">＋ 新建笔记</button><input v-model="noteSearch" placeholder="搜索..." style="width:100%;padding:.25rem .4rem;border:1px solid var(--border);border-radius:5px;font-size:.75rem;margin-bottom:.3rem;background:var(--card);color:var(--text);outline:none;"><div v-if="!notes.length" class="empty-state">还没有笔记</div><div v-for="n in filteredNotes" :key="n.id" :class="'note-list-item'+(currentId===n.id?' active':'')" @click="openNote(n.id)"><span class="ntitle">{{n.title||'无标题'}}</span><span class="ndate">{{new Date(n.updated).toLocaleDateString('zh-CN')}}</span></div></div>
  <div class="note-editor" v-if="currentId!==null||(title||content)"><input class="title" v-model="title" @input="dirty=true" placeholder="笔记标题..."><div class="toolbar"><button class="btn-sm" @click="insertMd('**','**')">B</button><button class="btn-sm" @click="insertMd('*','*')"><i>I</i></button><button class="btn-sm" @click="insertMd('\`','\`')">&lt;/&gt;</button><button class="btn-sm" @click="insertMd('\n- ','')">•</button><button class="btn-sm" @click="insertMd('\n# ','')">H</button><button class="btn outline" @click="exportToFiles">📁存到文件</button><button class="btn outline" @click="exportPdf" style="margin-left:auto;">📄导出PDF</button></div><div class="split-pane"><div class="pane"><div class="pane-header">编辑</div><textarea v-model="content" @input="updatePreview" placeholder="Markdown 内容..."></textarea></div><div class="pane"><div class="pane-header">预览</div><div class="preview" v-html="preview"></div></div></div><div class="toolbar" style="justify-content:flex-end;"><button class="btn danger" @click="del">删除</button></div></div></div>
</div></div>

<!-- 采集 -->
<div class="panel" id="panel-scrape"><div id="scrape-app" v-cloak><div v-if="!sessions.length" class="empty-state">还没有采集记录</div>
  <h2>🔍 网页采集</h2>
  <div class="scrape-form"><textarea v-model="urls" placeholder="支持三种方式：①智能展开 ②{起-止}模式 ③多行URL"></textarea><div class="scrape-opts"><label><input type="radio" v-model="type" value="images">📷图片</label><label><input type="radio" v-model="type" value="text">📄文本</label><label><input type="radio" v-model="type" value="both">📷📄两者</label><label><input type="radio" v-model="type" value="video">🎬视频</label><label><input type="radio" v-model="type" value="music">🎵音乐</label><label title="浏览器渲染后提取"><input type="checkbox" v-model="deepRender">🔧深度渲染</label><label title="跟踪详情页找原图"><input type="checkbox" v-model="followDetail">🔗跟踪详情</label><button class="btn accent" @click="start" :disabled="loading">{{loading?'⏳采集中...':'🚀开始采集'}}</button></div></div>
  <div v-if="progress" class="scrape-progress">{{progress}}</div>
  <div class="scrape-sessions"><div v-for="s in sessions" :key="s.sessionId" class="scrape-card"><div class="sc-header"><div><div class="sc-title">🌐{{s.title||s.url}}</div><div class="sc-meta">{{new Date(s.time).toLocaleString('zh-CN')}}·{{s.urlCount}}个页面·{{s.type==='images'?'📷':s.type==='text'?'📄':s.type==='video'?'🎬':s.type==='music'?'🎵':'📷📄'}}</div></div></div>
    <div v-if="s.images&&s.images.length">
      <div v-if="s.images.some(i=>i.name.startsWith('img_'))" class="sc-preview"><img v-for="img in s.images.filter(i=>i.name.startsWith('img_')).slice(0,8)" :key="img.name" loading="lazy" :src="'/api/scrape/thumb/'+s.sessionId+'/'+img.name" @click="window.open('/api/scrape/img/'+s.sessionId+'/'+img.name,'_blank')" :title="img.name"></div>
      <div v-if="s.images.some(i=>i.name.startsWith('vid_'))" style="display:flex;flex-direction:column;gap:.15rem;margin-top:.4rem;"><div v-for="img in s.images.filter(i=>i.name.startsWith('vid_')).slice(0,5)" :key="img.name" @click="window.open('/api/scrape/img/'+s.sessionId+'/'+img.name,'_blank')" :title="img.name" style="display:flex;align-items:center;gap:.3rem;padding:.3rem .5rem;background:var(--card);border:var(--shadow);border-radius:var(--radius-xs);cursor:pointer;font-size:.7rem;">🎬 <span style="flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{{img.name.replace('vid_','').slice(0,40)}}</span> <span style="color:var(--sub);font-size:.6rem;">{{(img.size/1024/1024).toFixed(1)}}MB</span></div></div>
      <div v-if="s.images.some(i=>i.name.startsWith('mus_'))" style="display:flex;flex-wrap:wrap;gap:.3rem;margin-top:.4rem;"><div v-for="img in s.images.filter(i=>i.name.startsWith('mus_')).slice(0,10)" :key="img.name" @click="window.open('/api/scrape/img/'+s.sessionId+'/'+img.name,'_blank')" :title="img.name" style="display:flex;align-items:center;gap:.3rem;padding:.3rem .5rem;background:var(--card);border:var(--shadow);border-radius:var(--radius-xs);cursor:pointer;font-size:.7rem;">🎵 <span style="flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{{img.name.replace('mus_','').slice(0,30)}}</span> <span style="color:var(--sub);font-size:.6rem;">{{(img.size/1024/1024).toFixed(1)}}MB</span></div></div>
    </div>
    <div v-if="s.texts&&s.texts.length" style="font-size:.8rem;margin-top:.3rem;">📄{{s.texts.map(t=>t.name).join(',')}}</div>
    <div class="sc-meta">共{{s.images? s.images.filter(i=>i.name.startsWith('img_')).length:0}}图 {{s.images? s.images.filter(i=>i.name.startsWith('vid_')).length:0}}视频 {{s.images? s.images.filter(i=>i.name.startsWith('mus_')).length:0}}音乐,{{s.textCount}}个文本<span v-if="s.detailFollowed">,🔗{{s.detailFollowed}}张从详情页获取</span><span v-if="s.skippedLowRes">,🔍{{s.skippedLowRes}}张低分辨率已过滤</span><span v-if="s.errorCount">,⚠️{{s.errorCount}}失败</span></div>
    <div class="sc-actions"><button class="btn-sm" @click="transfer(s.sessionId)">📁转存到文件</button><button class="btn-sm danger" @click="delSession(s.sessionId)">🗑删除</button></div></div></div>
  <div v-if="!sessions.length" class="empty-state">还没有采集记录</div>
</div></div>

<!-- 阅读器 -->
<div class="panel" id="panel-read" style="padding:0;max-width:100%;"><div id="read-app" v-cloak><div v-if="!currentBook" id="readerShelf" style="padding:1.5rem 1rem;max-width:900px;margin:0 auto;"><h2>📖 我的书架</h2><div class="grid" v-if="books.length" style="grid-template-columns:repeat(auto-fill,minmax(140px,1fr));"><div v-for="b in books" :key="b.name" class="book-card" @click="openBook(b.name)"><span class="cover">{{ {epub:'📗',pdf:'📕',txt:'📄',md:'📝'}[b.name.split('.').pop().toLowerCase()]||'📘' }}</span><span class="btitle">{{b.name}}</span><span class="bprogress">{{fmtSize(b.size)}}</span></div></div><div v-else class="empty-state">还没有可读的文件<br><small>上传EPUB/PDF/TXT/Markdown到文件中转站即可</small></div></div>
  <div v-else id="readerView"><div id="readerToolbar" style="display:flex;align-items:center;gap:.5rem;padding:.5rem 1rem;background:var(--card);border-bottom:1px solid var(--border);position:sticky;top:0;z-index:50;flex-wrap:wrap;"><button class="btn-sm" @click="close">←返回书架</button><span style="font-weight:600;font-size:.85rem;flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{{currentBook}}</span><select v-model="fontSize" @change="updateSettings" style="font-size:.75rem;padding:.2rem;border:1px solid var(--border);border-radius:4px;background:var(--card);color:var(--text);"><option v-for="s in ['16','18','20','22','24']" :key="s" :value="s">{{s}}px</option></select><select v-model="theme" @change="updateSettings" style="font-size:.75rem;padding:.2rem;border:1px solid var(--border);border-radius:4px;background:var(--card);color:var(--text);"><option value="light">☀️日间</option><option value="sepia">📜护眼</option><option value="dark">🌙夜间</option></select><button class="btn-sm" @click="toggleToc">☰目录</button><button class="btn-sm" @click="toggleAutoScroll" :style="autoScrolling?{background:'var(--accent)',color:'#fff'}:{}">{{autoScrolling?'⏸×'+autoScrollSpeed:'⏯自动滚屏'}}</button></div><div style="display:flex;"><div v-show="tocVisible" id="readerTOC" style="width:220px;border-right:1px solid var(--border);overflow-y:auto;padding:.5rem;background:var(--card);max-height:calc(100vh-90px);flex-shrink:0;"><div v-for="item in tocItems" :key="item.href" @click="tocVisible=false" style="padding:.3rem .5rem;cursor:pointer;font-size:.8rem;border-radius:4px;">{{item.label}}</div></div><div id="readerContent" style="flex:1;overflow-y:auto;height:calc(100vh-90px);"></div></div><div style="display:flex;justify-content:space-between;padding:.3rem 1rem;font-size:.7rem;color:var(--sub);background:var(--card);border-top:1px solid var(--border);"><span>{{position}}</span><span>←→翻页·↑↓空格滚动·F全屏·Esc回书架</span></div></div>
</div></div>

<!-- 翻译 -->
<div class="panel" id="panel-translate"><div id="translate-app" v-cloak><h2>🌐 翻译</h2><div style="display:flex;gap:.5rem;margin-bottom:.5rem;align-items:center;flex-wrap:wrap;"><select v-model="from"><option value="auto">自动检测</option><option value="zh">中文</option><option value="en">English</option><option value="ja">日本語</option><option value="ko">한국어</option><option value="fr">Français</option><option value="de">Deutsch</option><option value="es">Español</option><option value="ru">Русский</option><option value="pt">Português</option><option value="ar">العربية</option></select><button class="btn-sm" @click="swapLang" title="互换语言">⇄</button><select v-model="to" @change="autoTranslate"><option value="zh">中文</option><option value="en" selected>English</option><option value="ja">日本語</option><option value="ko">한국어</option><option value="fr">Français</option><option value="de">Deutsch</option><option value="es">Español</option><option value="ru">Русский</option><option value="pt">Português</option><option value="ar">العربية</option></select><button class="btn outline" @click="saveToNotes">💾存笔记</button><button class="btn outline" @click="copy">📋复制</button><button class="btn outline" @click="speakInput" :disabled="!inputText" title="朗读原文">🔊原文</button><button class="btn outline" @click="speakOutput" :disabled="!outputText||outputText.startsWith('❌')" title="朗读译文">🔊译文</button><label class="btn-sm" style="cursor:pointer;">📁打开文件<input type="file" accept=".txt,.md,.srt,.vtt" @change="loadFile" style="display:none;"></label></div>
  <div style="display:flex;gap:1rem;min-height:300px;"><textarea v-model="inputText" @input="autoTranslate" placeholder="输入要翻译的文本..."></textarea><textarea v-model="outputText" readonly placeholder="翻译结果..."></textarea></div>
  <div style="margin-top:1rem;"><div class="section-title" style="display:flex;justify-content:space-between;"><span>📋翻译历史({{history.length}})</span><button class="btn-sm danger" @click="clearHistory">清空</button></div><div v-if="!history.length" class="empty-state">暂无翻译记录</div><div v-for="(h,i) in history" :key="i" style="display:flex;align-items:center;padding:.5rem;border-bottom:1px solid var(--border);font-size:.8rem;"><div style="flex:1;cursor:pointer;" @click="loadHistory(h)"><span style="color:var(--sub);">{{h.time}}</span><span>{{esc(h.from.slice(0,60))}}</span>→<span style="color:var(--accent);">{{esc(h.to.slice(0,60))}}</span></div><button class="btn-sm danger" @click="delHistory(i)">✕</button></div></div>
</div></div>

<!-- AI -->
<div class="panel" id="panel-ai"><div id="ai-app" v-cloak><div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:.5rem;"><h2 style="margin:0;">🤖多模型对比</h2><span style="font-size:.8rem;color:var(--sub);">同一问题，多个AI同时回答</span><button class="btn-sm" @click="agentMode=!agentMode" :style="{background:agentMode?'var(--accent)':'var(--card)',color:agentMode?'#fff':'var(--text)'}">{{agentMode?'🤖智能体':'⚡对比'}}</button><button class="btn-sm" @click="stopAll" id="aiStopBtn" v-show="isGenerating" style="background:var(--danger);color:#fff;border-color:var(--danger);">⏹停止</button></div>
  <div style="display:flex;gap:.5rem;padding:.3rem 0;align-items:center;flex-wrap:wrap;font-size:.7rem;"><span>温度</span><input type="range" v-model.number="temperature" min="0" max="2" step="0.1"><span>{{temperature}}</span><button class="btn-sm" @click="saveToNotes" style="margin-left:auto;">💾存笔记</button><button class="btn-sm" @click="newSession">＋新会话</button><button class="btn-sm" @click="clearAll">清空</button></div>
  <div style="display:flex;gap:.3rem;padding:.2rem 0;overflow-x:auto;font-size:.7rem;"><div v-for="s in sessions" :key="s.id" @click="loadSession(s.id)" style="padding:.2rem .4rem;background:var(--card);border:1px solid var(--border);border-radius:5px;cursor:pointer;white-space:nowrap;display:flex;align-items:center;gap:.3rem;"><span>{{s.title}}</span><span style="color:var(--sub);">{{s.time}}</span><button class="btn-sm danger" @click.stop="deleteSession(s.id)" style="font-size:.6rem;padding:0 .2rem;">✕</button></div></div>
  <div v-if="agentMode" style="display:flex;gap:.3rem;padding:.2rem 0;overflow-x:auto;font-size:.7rem;flex-wrap:wrap;"><div v-for="a in agents" :key="a.id" @click="selectAgent(a)" :style="{padding:'.25rem .5rem',borderRadius:'8px',cursor:'pointer',background:currentAgent?.id===a.id?'var(--accent)':'var(--card)',color:currentAgent?.id===a.id?'#fff':'var(--text)',border:'1px solid '+(currentAgent?.id===a.id?'var(--accent)':'var(--border)'),whiteSpace:'nowrap'}">{{a.icon}}{{a.name}}</div></div><div v-if="!agentMode" style="display:flex;gap:1rem;padding:.3rem 0;flex-wrap:wrap;"><label v-for="m in models" :key="m.id" style="font-size:.75rem;display:flex;align-items:center;gap:.2rem;cursor:pointer;"><input type="checkbox" v-model="m.enabled" @change="saveToggles">{{m.icon}}{{m.name}}</label></div>
  <div :style="gridStyle" style="display:grid;gap:.5rem;flex:1;min-height:0;"><div v-for="m in enabledModels" :key="m.col" :id="m.col" class="ai-col" style="display:flex;flex-direction:column;border:1px solid var(--border);border-radius:10px;overflow:hidden;"><div style="padding:.35rem .6rem;background:var(--card);border-bottom:1px solid var(--border);font-weight:600;font-size:.8rem;">{{m.icon}}{{m.name}}<span v-if="m._responseTime" style="font-weight:normal;font-size:.65rem;color:var(--sub);">({{m._responseTime}})</span><button class="btn-sm" @click="retryModel(m.id)" style="float:right;font-size:.7rem;">🔄</button></div><div class="ai-col-msgs" style="flex:1;overflow-y:auto;padding:.4rem;"><div v-for="msg in m.messages" :key="msg.id" :class="'ai-msg '+msg.role"><div class="avatar">{{msg.role==='user'?'👤':m.icon}}</div><div class="bubble" v-html="msg.role==='assistant'?formatAI(msg.content):esc(msg.content)"></div></div></div></div></div>
  <div style="display:flex;gap:.5rem;padding:.5rem 0;"><textarea v-model="inputText" @keydown="onKeydown" placeholder="Enter发送，Ctrl+Enter换行" rows="2" style="flex:1;padding:.6rem;border:1px solid var(--border);border-radius:10px;background:var(--card);color:var(--text);font-size:.9rem;resize:none;font-family:inherit;outline:none;"></textarea><button class="btn accent" @click="sendMessage" style="align-self:flex-end;">发送</button></div>
</div></div>

<!-- 语音 -->
<div class="panel" id="panel-voice" style="max-width:900px;"><div id="voice-app" v-cloak><h2>🎙️语音工具</h2>
<div style="display:flex;gap:1.5rem;flex-wrap:wrap"><div style="flex:1;min-width:300px"><h3>📢文字转语音</h3><textarea v-model="ttsText" placeholder="输入要朗读的文字..." rows="6" style="width:100%;padding:.6rem;border:1px solid var(--border);border-radius:10px;background:var(--card);color:var(--text);font-size:.9rem;resize:vertical;font-family:inherit;outline:none"></textarea><div style="display:flex;gap:.5rem;margin-top:.5rem"><select v-model="ttsVoice" style="padding:.3rem;border:1px solid var(--border);border-radius:6px;background:var(--card);color:var(--text);font-size:.8rem;flex:1"><option v-for="v in voices" :key="v.name" :value="v.name">{{v.label}}</option></select><button class="btn accent" @click="speak">{{ttsLoading?"⏳...":"🔊朗读"}}</button><button class="btn outline" @click="saveTTSAudio">📁存文件</button></div></div><div style="flex:1;min-width:300px"><h3>🎤语音转文字</h3><div @click="toggleSTT" :style="{padding:'2rem',textAlign:'center',border:'2px dashed '+(sttListening?'var(--danger)':'var(--border)'),borderRadius:'12px',marginBottom:'.5rem',cursor:'pointer'}"><div style="font-size:3rem">{{sttListening?"🔴":"🎤"}}</div><div style="color:var(--sub);font-size:.85rem">{{sttListening?"正在录音...点击停止":"点击开始录音"}}</div></div><div style="min-height:120px;padding:.6rem;border:1px solid var(--border);border-radius:10px;background:var(--card);color:var(--text);font-size:.9rem;white-space:pre-wrap">{{sttText}}</div><div style="display:flex;gap:.5rem;margin-top:.5rem"><button class="btn outline" @click="copySTT">📋复制</button><button class="btn outline" @click="saveSTT">💾存笔记</button><button class="btn outline" @click="clearSTT">清空</button></div></div></div></div>

<div class="modal-overlay" id="previewModal" onclick="if(event.target===this)closePreview()"><div class="modal"><div class="modal-header"><span class="m-title" id="previewTitle"></span><button class="m-close" onclick="closePreview()">✕</button></div><div class="modal-body" id="previewBody"></div></div></div>
<div class="toast" id="toast"></div>

<div id="musicPlayer" style="display:flex;position:fixed;bottom:0;left:0;right:0;background:var(--card);border-top:1px solid var(--border);padding:.4rem 1rem;z-index:100;align-items:center;gap:.8rem;font-size:.8rem;box-shadow:0 -2px 8px rgba(0,0,0,0.1);"><span style="font-weight:600;max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" id="mpTitle">🎵</span><button class="btn-sm" onclick="musicPlayer.prev()">⏮</button><button class="btn-sm" onclick="musicPlayer.toggle()" id="mpPlayBtn">▶️</button><button class="btn-sm" onclick="musicPlayer.next()">⏭</button><input type="range" id="mpVolume" min="0" max="100" value="70" oninput="musicPlayer.audio.volume=this.value/100" style="width:80px;accent-color:var(--accent);"><button class="btn-sm" onclick="musicPlayer.toggleLoop()" id="mpLoopBtn">🔁</button><button class="btn-sm" onclick="musicPlayer.toggleShuffle()" id="mpShuffleBtn">🔀</button><span style="font-size:.65rem;color:var(--sub);" id="mpTime">0:00</span><button class="btn-sm danger" onclick="musicPlayer.stop()" style="margin-left:auto;">✕</button></div>
<script>window.musicPlayer={playlist:[],index:0,loop:false,shuffle:false,audio:new Audio(),init(){this.audio.addEventListener('timeupdate',()=>{const m=Math.floor(this.audio.currentTime/60);const s=Math.floor(this.audio.currentTime%60).toString().padStart(2,'0');document.getElementById('mpTime').textContent=m+':'+s});this.audio.addEventListener('ended',()=>{if(this.loop&&this.playlist.length===1)this.audio.play();else this.next()});this.audio.addEventListener('error',()=>this.next())},add(files){this.playlist.push(...files);if(this.playlist.length===files.length)this.play(0);this.show()},play(i){if(!this.playlist.length)return;this.index=((i%this.playlist.length)+this.playlist.length)%this.playlist.length;const f=this.playlist[this.index];this.audio.src='/api/view/'+encodeURIComponent(f.name);document.getElementById('mpTitle').textContent='🎵 '+f.name;document.getElementById('mpPlayBtn').textContent='⏸';this.audio.play().catch(()=>{});this.show()},toggle(){if(this.audio.paused){this.audio.play();document.getElementById('mpPlayBtn').textContent='⏸'}else{this.audio.pause();document.getElementById('mpPlayBtn').textContent='▶️'}},next(){if(this.shuffle&&this.playlist.length>1)this.play(Math.floor(Math.random()*this.playlist.length));else this.play(this.index+1)},prev(){this.play(this.index-1)},toggleLoop(){this.loop=!this.loop;document.getElementById('mpLoopBtn').style.opacity=this.loop?'1':'0.3'},toggleShuffle(){this.shuffle=!this.shuffle;document.getElementById('mpShuffleBtn').style.opacity=this.shuffle?'1':'0.3'},stop(){this.audio.pause();document.getElementById('musicPlayer').style.opacity='0.5';this.playlist=[];document.getElementById('mpTitle').textContent='🎵 空闲';document.getElementById('mpPlayBtn').textContent='▶️'},show(){const e=document.getElementById('musicPlayer');e.style.display='flex';e.style.opacity='1'}};musicPlayer.init(); setTimeout(()=>{if(!musicPlayer.playlist.length) document.getElementById("musicPlayer").style.opacity="0.5"},100);</script>

<script src="/js/common.js"></script>
<script src="/js/files.js"></script>
<script src="/js/notes.js"></script>
<script src="/js/scraper.js"></script>
<script src="/js/reader.js"></script>
<script src="/js/translate.js"></script>
<script src="/js/ai.js"></script>
<script src="/js/voice.js"></script>
<div id="musicPlayer" style="display:none;position:fixed;bottom:0;left:0;right:0;background:var(--card);border-top:1px solid var(--border);padding:.4rem 1rem;z-index:100;align-items:center;gap:.8rem;font-size:.8rem;box-shadow:0 -2px 8px rgba(0,0,0,0.1);"><span style="font-weight:600;max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" id="mpTitle">🎵</span><button class="btn-sm" onclick="musicPlayer.prev()">⏮</button><button class="btn-sm" onclick="musicPlayer.toggle()" id="mpPlayBtn">▶️</button><button class="btn-sm" onclick="musicPlayer.next()">⏭</button><input type="range" id="mpVolume" min="0" max="100" value="70" oninput="musicPlayer.audio.volume=this.value/100" style="width:80px;accent-color:var(--accent);"><button class="btn-sm" onclick="musicPlayer.toggleLoop()" id="mpLoopBtn">🔁</button><button class="btn-sm" onclick="musicPlayer.toggleShuffle()" id="mpShuffleBtn">🔀</button><span style="font-size:.65rem;color:var(--sub);" id="mpTime">0:00</span><button class="btn-sm danger" onclick="musicPlayer.stop()" style="margin-left:auto;">✕</button></div></body>
</html>
